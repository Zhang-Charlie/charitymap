# Local PostgreSQL used by Docker Compose
POSTGRES_DB=charitymap
POSTGRES_USER=charitymap
POSTGRES_PASSWORD=charitymap
DATABASE_URL=postgresql+psycopg://charitymap:charitymap@localhost:5432/charitymap

# Supabase values for deployed environments
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Optional hosted map style URL
NEXT_PUBLIC_MAP_STYLE_URL=
