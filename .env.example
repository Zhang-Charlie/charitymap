# Local PostgreSQL used by Docker Compose
POSTGRES_DB=charitymap
POSTGRES_USER=charitymap
POSTGRES_PASSWORD=charitymap
DATABASE_URL=postgresql+psycopg://charitymap:charitymap@localhost:5432/charitymap
IMPORT_WRITE_ENABLED=false

# Required for the IATI importer. Obtain an API subscription key from IATI.
IATI_API_KEY=
# Select one reporting organisation reference for the capped first import.
IATI_PUBLISHER_REF=
IATI_MAX_RECORDS=100
IATI_TIMEOUT_SECONDS=20

# Supabase values for deployed environments
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Optional hosted map style URL
NEXT_PUBLIC_MAP_STYLE_URL=
